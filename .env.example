TG_TOKEN=your_telegram_bot_token
MAX_TOKEN=your_max_bot_token


# Список разрешённых Telegram user ID через запятую.
# Если не задан — бот доступен всем пользователям.
# Узнать свой ID можно у @userinfobot в Telegram.
# ADMIN_IDS=123456789,987654321

# Максимальный размер файла при пересылке (в МБ). 0 или не задано — без ограничений.
# TG→MAX: Telegram getFile API ограничен 20 МБ.
# MAX→TG: Telegram Bot API sendDocument ограничен 50 МБ.
# TG_MAX_FILE_SIZE_MB=20
# MAX_MAX_FILE_SIZE_MB=20

# SQLite (по умолчанию, без docker-compose)
# DB_PATH=bridge.db

# PostgreSQL (docker-compose)
# POSTGRES_USER=bridge
# POSTGRES_PASSWORD=bridge
# POSTGRES_DB=bridge

# Webhook (опционально)
# WEBHOOK_URL=https://bridge.example.com
# WEBHOOK_PORT=8443
